generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CONFIGURING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum InternalRole {
  ADMIN
  COMMERCIAL
  OPERATOR
  SUPPORT
  READONLY
}

enum CustomerRole {
  ADMIN
  BUYER
}

enum IntegrationAuthMethod {
  API_KEY
  BEARER_TOKEN
  BASIC_AUTH
  OAUTH2
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SyncDirection {
  INBOUND
  OUTBOUND
}

enum OrderSyncStatus {
  DRAFT
  SUBMITTED
  PENDING_ERP
  SENDING_TO_ERP
  SYNCED
  PENDING_VERIFICATION
  SYNC_FAILED
  QUEUED_RETRY
}

enum DetailFetchOn {
  ON_BATCH
  ON_DEMAND
}

enum SyncResource {
  CUSTOMERS
  PRODUCTS
  PRICE_LISTS
  PRICE_ASSIGNMENTS
  INVOICES
  RECEIVABLES
  ORDERS
  SMART_BASKET
  PAYMENTS
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum OrderStatus {
  PENDING_APPROVAL
  OPEN
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketCategory {
  ORDER_ISSUE
  BILLING
  TECHNICAL
  ACCOUNT
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Company (Tenant) ────────────────────────────────────────────

model Company {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  taxId          String?
  phone          String?
  website        String?
  address        String?
  logo           String?
  corporateEmail String?
  socialLinks    Json? // { linkedin, instagram, facebook, twitter/x }
  status         CompanyStatus @default(CONFIGURING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  branding      CompanyBranding?
  internalUsers InternalUser[]
  integrations  Integration[]
  customers     Customer[]
  products      Product[]
  invoices      Invoice[]
  receivables   AccountReceivable[]
  orders        Order[]
  tickets       Ticket[]
  auditLogs     AuditLog[]
  smartBasketConfig SmartBasketConfig?
  notifications Notification[]
  customerUsers CustomerUser[]
}

model CompanyBranding {
  id             String  @id @default(cuid())
  companyId      String  @unique
  primaryColor   String  @default("#0F172A")
  secondaryColor String  @default("#3B82F6")
  logoUrl        String?
  faviconUrl     String?
  portalTitle    String?
  customCss      String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── RBAC (Roles & Permissions) ──────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "orders:view", "orders:print"
  name        String
  description String?
  module      String   // e.g., "ORDERS", "INTEGRATIONS"
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model Role {
  id          String   @id @default(cuid())
  companyId   String?  // null for System Roles (global)
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       InternalUser[]

  @@unique([companyId, name])
  @@index([companyId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─── Internal Users ──────────────────────────────────────────────

model InternalUser {
  id           String       @id @default(cuid())
  companyId    String
  firstName    String
  lastName     String
  email        String       @unique
  passwordHash String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleId          String?      // New dynamic role
  role            Role?        @relation(fields: [roleId], references: [id])
  legacyRole      InternalRole @default(OPERATOR) // To be removed after migration
  status          UserStatus   @default(ACTIVE)
  lastLoginAt     DateTime?
  lastActiveAt    DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  auditLogs       AuditLog[]
  emailConfig     EmailConfig?
  assignedTickets Ticket[]     @relation("AssignedTo")
  tokens          VerificationToken[] @relation("InternalTokens")

  @@index([companyId])
  @@index([email])
}

model EmailConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  provider    String   @default("CUSTOM") // GMAIL, OUTLOOK, CUSTOM
  host        String?
  port        Int?
  smtpUser    String
  password    String // encrypted
  imapHost    String?
  imapPort    Int?
  fromAddress String
  fromName    String?
  useTLS      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user InternalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Integrations ────────────────────────────────────────────────

model Integration {
  id           String                @id @default(cuid())
  companyId    String
  name         String
  description  String?
  authMethod   IntegrationAuthMethod
  baseUrl      String
  credentials  Json // encrypted in prod
  headers      Json? // extra fixed headers
  testEndpoint String? // endpoint to test connectivity
  isActive     Boolean               @default(false)
  lastSyncAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  company  Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mappings IntegrationMapping[]
  syncJobs IntegrationSyncJob[]

  @@index([companyId])
}

model IntegrationMapping {
  id               String       @id @default(cuid())
  integrationId    String
  resource         SyncResource
  externalEndpoint String
  direction        SyncDirection @default(INBOUND)
  method           String        @default("GET") // GET for inbound, POST/PUT for outbound
  fieldMappings    Json // Inbound: ERP -> Canonical, Outbound: Canonical -> ERP
  transforms       Json? // { field: { map: {}, format: "" } }
  paginationConfig Json? // Inbound only
  extendedFieldsDef Json? // { field: { label, type, required, options[] } }
  detailEndpoint   String? // Path with {externalId} for on-demand fetch
  detailDataPath   String? // Path to the lines array in detail response (e.g., 'products')
  detailFetchOn    DetailFetchOn @default(ON_BATCH)
  detailFieldMappings Json? // For order lines / detail entities
  successIdField   String? // e.g. "erp_number"
  isActive         Boolean      @default(true)
  // ─── Scheduling (Inbound Only) ──────────────────────
  isScheduled      Boolean      @default(false)
  syncCron         String? // cron expression e.g. "0 2 * * *" = daily at 2 AM
  syncInterval     String? // human-readable interval e.g. "every 6 hours"
  nextRunAt        DateTime? // when the next run will fire
  lastScheduledAt  DateTime? // when it was last triggered by scheduler
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, resource, direction])
  @@index([integrationId])
  @@index([isScheduled, nextRunAt]) // for efficient scheduler queries
}

model IntegrationSyncJob {
  id            String       @id @default(cuid())
  integrationId String
  resource      SyncResource
  direction     SyncDirection @default(INBOUND)
  status        SyncStatus   @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  recordsTotal  Int          @default(0)
  recordsOk     Int          @default(0)
  recordsFailed Int          @default(0)
  errorSummary  String?
  triggeredBy   String? // user id or "scheduler"
  createdAt     DateTime     @default(now())

  integration Integration          @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  logs        IntegrationSyncLog[]

  @@index([integrationId])
}

model IntegrationSyncLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String // info | warn | error
  message   String
  details   Json?
  createdAt DateTime @default(now())

  job IntegrationSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ─── Customers ───────────────────────────────────────────────────

model Customer {
  id            String         @id @default(cuid())
  companyId     String
  internalCode  String? // NexoB2B unique code: CLT-YYYYMM-XXXXXXXX
  externalId    String? // ID in ERP
  name          String
  taxId         String?
  email         String?
  phone         String?
  address       String?
  status        CustomerStatus @default(ACTIVE)
  portalEnabled Boolean        @default(false)
  maxUsers      Int            @default(5)
  creditLimit   Decimal?       @db.Decimal(18, 2) @default(0)
  erpMetadata     Json? // metadata for level 2 resolution
  syncedAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company         Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           CustomerUser[]
  priceAssignment CustomerPriceAssignment?
  invoices        Invoice[]
  receivables     AccountReceivable[]
  orders          Order[]
  tickets         Ticket[]
  smartBasketSuggestions SmartBasketSuggestion[]

  @@unique([companyId, externalId])
  @@unique([companyId, internalCode])
  @@index([companyId])
}

model CustomerUser {
  id           String       @id @default(cuid())
  companyId    String
  customerId   String
  firstName    String
  lastName     String
  email        String       @unique
  passwordHash String
  role         CustomerRole @default(BUYER)
  status       UserStatus   @default(INVITED)
  requiresApproval Boolean  @default(false)
  orderLimit       Float?
  lastLoginAt  DateTime?
  lastActiveAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]             @relation("SubmittedBy")
  approvedOrders Order[]       @relation("ApprovedBy")
  tickets  Ticket[]            @relation("RaisedBy")
  tokens   VerificationToken[]

  @@index([customerId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String?
  token     String   @unique
  type      String // INVITATION, PASSWORD_RESET
  expiresAt DateTime
  createdAt DateTime @default(now())

  user     CustomerUser? @relation(fields: [userId], references: [id], onDelete: Cascade)
  internalUser InternalUser? @relation("InternalTokens", fields: [internalUserId], references: [id], onDelete: Cascade)
  internalUserId String?

  @@index([userId])
  @@index([internalUserId])
}

// ─── Products & Pricing ──────────────────────────────────────────

model Product {
  id           String    @id @default(cuid())
  companyId    String
  internalCode String? // NexoB2B unique code: PRD-YYYYMM-XXXXXXXX
  externalId   String?
  sku          String
  name         String
  description  String?
  category     String?
  brand        String?
  unit         String?
  imageUrl     String?
  stock        Decimal   @default(0) @db.Decimal(18, 4)
  isVisible    Boolean   @default(true)
  isActive     Boolean   @default(true)
  syncedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company        Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  priceSnapshots ProductPriceSnapshot[]
  orderItems     OrderItem[]
  smartBasketSuggestions SmartBasketSuggestion[]

  @@unique([companyId, sku])
  @@unique([companyId, internalCode])
  @@index([companyId])
}

model ProductPriceSnapshot {
  id          String   @id @default(cuid())
  productId   String
  priceListId String // e.g. "1", "2", "LISTA_A"
  price       Decimal  @db.Decimal(18, 4)
  currency    String   @default("DOP")
  syncedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, priceListId])
  @@index([productId])
}

model CustomerPriceAssignment {
  id          String   @id @default(cuid())
  customerId  String   @unique
  priceListId String
  source      String // "erp" | "manual"
  syncedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── Invoices ────────────────────────────────────────────────────

model Invoice {
  id           String        @id @default(cuid())
  companyId    String
  customerId   String
  internalCode String? // NexoB2B unique code: FAC-YYYYMM-XXXXXXXX
  externalId   String?
  number       String
  date         DateTime
  dueDate      DateTime?
  subtotal     Decimal       @db.Decimal(18, 2)
  tax          Decimal       @default(0) @db.Decimal(18, 2)
  total        Decimal       @db.Decimal(18, 2)
  currency     String        @default("DOP")
  status       InvoiceStatus @default(PENDING)
  notes        String?
  syncedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([customerId])
}

// ─── Accounts Receivable ─────────────────────────────────────────

model AccountReceivable {
  id          String    @id @default(cuid())
  companyId   String
  customerId  String
  externalId  String?
  documentRef String?
  amount      Decimal   @db.Decimal(18, 2)
  balance     Decimal   @db.Decimal(18, 2)
  currency    String    @default("DOP")
  dueDate     DateTime?
  syncedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([customerId])
}

// ─── Orders ──────────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  companyId     String
  customerId    String
  internalCode  String? // NexoB2B unique code: ORD-YYYYMM-XXXXXXXX
  externalId    String?
  number        String
  date          DateTime
  status        OrderStatus @default(OPEN)
  total         Decimal     @db.Decimal(18, 2)
  currency      String      @default("DOP")
  notes         String?
  syncStatus     OrderSyncStatus @default(DRAFT)
  extendedFields Json? // level 3 resolution fields
  idempotencyKey String?
  syncedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  submittedById  String?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Customer      @relation(fields: [customerId], references: [id])
  submittedBy CustomerUser? @relation("SubmittedBy", fields: [submittedById], references: [id])
  approvedBy  CustomerUser? @relation("ApprovedBy", fields: [approvedById], references: [id])
  items       OrderItem[]

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([customerId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  sku       String
  name      String
  quantity  Decimal @db.Decimal(18, 4)
  unitPrice Decimal @db.Decimal(18, 4)
  total     Decimal @db.Decimal(18, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ─── Audit ───────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  userEmail  String?
  action     String // e.g. "USER_LOGIN", "CUSTOMER_INVITED"
  resource   String? // e.g. "Customer", "Integration"
  resourceId String?
  details    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    InternalUser? @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Support Tickets ─────────────────────────────────────────────

model Ticket {
  id               String         @id @default(cuid())
  companyId        String
  customerId       String
  raisedById       String?
  subject          String
  status           TicketStatus   @default(OPEN)
  priority         TicketPriority @default(MEDIUM)
  assignedToId     String?
  category         TicketCategory @default(OTHER)
  relatedOrderId   String?
  relatedInvoiceId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  raisedBy   CustomerUser?   @relation("RaisedBy", fields: [raisedById], references: [id])
  assignedTo InternalUser?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  messages   TicketMessage[]

  @@index([companyId])
  @@index([customerId])
  @@index([status])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String? // Can be InternalUser.id or CustomerUser.id
  senderType String // "INTERNAL" | "CUSTOMER"
  senderName String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─── Smart Basket ────────────────────────────────────────────────

model SmartBasketConfig {
  id             String      @id @default(cuid())
  companyId      String      @unique
  isActive       Boolean     @default(false)
  frequency      String      @default("24h")    // 12h, 24h, 48h, manual
  executionHour  String      @default("02:00")
  historyWindow  Int         @default(180)      // 90, 120, 180
  minScore       Int         @default(50)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  lastRunStatus  SyncStatus?
  lastRunError   String?
  processedCount Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SmartBasketSuggestion {
  id                String   @id @default(cuid())
  customerId        String
  productId         String
  smartScore        Int
  suggestedQuantity Decimal  @db.Decimal(18, 4)
  urgency           String   // "vencido", "proximo", "sugerido"
  patternText       String?  // e.g. "Compras cada ~7 días · Último: hace 8 días"
  lastPurchaseDate  DateTime?
  averageInterval   Float?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

// ─── Notifications ───────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  userId     String? // Can be CustomerUser.id or InternalUser.id
  userType   String // "CUSTOMER" | "INTERNAL"
  companyId  String
  type       String // "ORDER_STATUS", "INVOICE_DUE", "TICKET_REPLY", "INFO"
  title      String
  body       String
  link       String? // Redirect URL
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
}
