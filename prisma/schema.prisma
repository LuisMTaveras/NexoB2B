generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  CONFIGURING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum InternalRole {
  ADMIN
  COMMERCIAL
  OPERATOR
  SUPPORT
  READONLY
}

enum CustomerRole {
  ADMIN
  BUYER
}

enum IntegrationAuthMethod {
  API_KEY
  BEARER_TOKEN
  BASIC_AUTH
  OAUTH2
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SyncResource {
  CUSTOMERS
  PRODUCTS
  PRICE_LISTS
  PRICE_ASSIGNMENTS
  INVOICES
  RECEIVABLES
  ORDERS
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum OrderStatus {
  OPEN
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Company (Tenant) ────────────────────────────────────────────

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  taxId     String?
  phone     String?
  website   String?
  address   String?
  logo      String?
  status    CompanyStatus @default(CONFIGURING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  branding      CompanyBranding?
  internalUsers InternalUser[]
  integrations  Integration[]
  customers     Customer[]
  products      Product[]
  invoices      Invoice[]
  receivables   AccountReceivable[]
  orders        Order[]
  auditLogs     AuditLog[]
}

model CompanyBranding {
  id             String  @id @default(cuid())
  companyId      String  @unique
  primaryColor   String  @default("#0F172A")
  secondaryColor String  @default("#3B82F6")
  logoUrl        String?
  faviconUrl     String?
  portalTitle    String?
  customCss      String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Internal Users ──────────────────────────────────────────────

model InternalUser {
  id           String       @id @default(cuid())
  companyId    String
  firstName    String
  lastName     String
  email        String       @unique
  passwordHash String
  role         InternalRole @default(OPERATOR)
  status       UserStatus   @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([companyId])
  @@index([email])
}

// ─── Integrations ────────────────────────────────────────────────

model Integration {
  id            String                @id @default(cuid())
  companyId     String
  name          String
  description   String?
  authMethod    IntegrationAuthMethod
  baseUrl       String
  credentials   Json                  // encrypted in prod
  headers       Json?                 // extra fixed headers
  testEndpoint  String?               // endpoint to test connectivity
  isActive      Boolean               @default(false)
  lastSyncAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  company  Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mappings IntegrationMapping[]
  syncJobs IntegrationSyncJob[]

  @@index([companyId])
}

model IntegrationMapping {
  id               String       @id @default(cuid())
  integrationId    String
  resource         SyncResource
  externalEndpoint String
  fieldMappings    Json         // { internalField: externalField | "=CONSTANT" }
  paginationConfig Json?        // PaginationConfig: { type, pageParam, pageSizeParam, pageSize, dataPath, totalPath }
  queryParams      Json?        // extra query params
  isActive         Boolean      @default(true)
  // ─── Scheduling ──────────────────────────────────────
  isScheduled      Boolean      @default(false)
  syncCron         String?      // cron expression e.g. "0 2 * * *" = daily at 2 AM
  syncInterval     String?      // human-readable interval e.g. "every 6 hours"
  nextRunAt        DateTime?    // when the next run will fire
  lastScheduledAt  DateTime?    // when it was last triggered by scheduler
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([isScheduled, nextRunAt]) // for efficient scheduler queries
  @@unique([integrationId, resource])
}

model IntegrationSyncJob {
  id            String       @id @default(cuid())
  integrationId String
  resource      SyncResource
  status        SyncStatus   @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  recordsTotal  Int          @default(0)
  recordsOk     Int          @default(0)
  recordsFailed Int          @default(0)
  errorSummary  String?
  triggeredBy   String?      // user id or "scheduler"
  createdAt     DateTime     @default(now())

  integration Integration        @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  logs        IntegrationSyncLog[]

  @@index([integrationId])
}

model IntegrationSyncLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String   // info | warn | error
  message   String
  details   Json?
  createdAt DateTime @default(now())

  job IntegrationSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ─── Customers ───────────────────────────────────────────────────

model Customer {
  id            String         @id @default(cuid())
  companyId     String
  internalCode  String?        // NexoB2B unique code: CLT-YYYYMM-XXXXXXXX
  externalId    String?        // ID in ERP
  name          String
  taxId         String?
  email         String?
  phone         String?
  address       String?
  status        CustomerStatus @default(ACTIVE)
  portalEnabled Boolean        @default(false)
  syncedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company         Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           CustomerUser[]
  priceAssignment CustomerPriceAssignment?
  invoices        Invoice[]
  receivables     AccountReceivable[]
  orders          Order[]

  @@unique([companyId, externalId])
  @@unique([companyId, internalCode])
  @@index([companyId])
}

model CustomerUser {
  id           String       @id @default(cuid())
  customerId   String
  firstName    String
  lastName     String
  email        String       @unique
  passwordHash String
  role         CustomerRole @default(BUYER)
  status       UserStatus   @default(INVITED)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── Products & Pricing ──────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  companyId    String
  internalCode String?  // NexoB2B unique code: PRD-YYYYMM-XXXXXXXX
  externalId   String?
  sku          String
  name         String
  description  String?
  category     String?
  brand        String?
  unit         String?
  imageUrl     String?
  isVisible    Boolean  @default(true)
  isActive     Boolean  @default(true)
  syncedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company        Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  priceSnapshots ProductPriceSnapshot[]
  orderItems     OrderItem[]

  @@unique([companyId, sku])
  @@unique([companyId, internalCode])
  @@index([companyId])
}

model ProductPriceSnapshot {
  id          String   @id @default(cuid())
  productId   String
  priceListId String   // e.g. "1", "2", "LISTA_A"
  price       Decimal  @db.Decimal(18, 4)
  currency    String   @default("DOP")
  syncedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, priceListId])
  @@index([productId])
}

model CustomerPriceAssignment {
  id          String   @id @default(cuid())
  customerId  String   @unique
  priceListId String
  source      String   // "erp" | "manual"
  syncedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── Invoices ────────────────────────────────────────────────────

model Invoice {
  id           String        @id @default(cuid())
  companyId    String
  customerId   String
  internalCode String?       // NexoB2B unique code: FAC-YYYYMM-XXXXXXXX
  externalId   String?
  number       String
  date         DateTime
  dueDate      DateTime?
  subtotal     Decimal       @db.Decimal(18, 2)
  tax          Decimal       @db.Decimal(18, 2) @default(0)
  total        Decimal       @db.Decimal(18, 2)
  currency     String        @default("DOP")
  status       InvoiceStatus @default(PENDING)
  notes        String?
  syncedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([customerId])
}

// ─── Accounts Receivable ─────────────────────────────────────────

model AccountReceivable {
  id          String   @id @default(cuid())
  companyId   String
  customerId  String
  externalId  String?
  documentRef String?
  amount      Decimal  @db.Decimal(18, 2)
  balance     Decimal  @db.Decimal(18, 2)
  currency    String   @default("DOP")
  dueDate     DateTime?
  syncedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([customerId])
}

// ─── Orders ──────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  companyId    String
  customerId   String
  internalCode String?     // NexoB2B unique code: ORD-YYYYMM-XXXXXXXX
  externalId   String?
  number       String
  date         DateTime
  status       OrderStatus @default(OPEN)
  total        Decimal     @db.Decimal(18, 2)
  currency     String      @default("DOP")
  notes        String?
  syncedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer    @relation(fields: [customerId], references: [id])
  items      OrderItem[]

  @@unique([companyId, externalId])
  @@index([companyId])
  @@index([customerId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  sku       String
  name      String
  quantity  Decimal @db.Decimal(18, 4)
  unitPrice Decimal @db.Decimal(18, 4)
  total     Decimal @db.Decimal(18, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ─── Audit ───────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  userEmail  String?
  action     String   // e.g. "USER_LOGIN", "CUSTOMER_INVITED"
  resource   String?  // e.g. "Customer", "Integration"
  resourceId String?
  details    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    InternalUser? @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
}
